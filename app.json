{
  "expo": {
    "name": "ChefMate",
    "slug": "chefmate-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "chefmate",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E66B3D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chefmate.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E66B3D"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.chefmate.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "owner": "sololabs",
    "extra": {
      "eas": {
        "projectId": "aaabe5b3-03fa-4030-980e-becbf76d3e18"
      },
      "router": {}
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#E66B3D"
        }
      ]
    ]
  }
}
